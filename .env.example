# ==============================================================================
#                      TASKRA SYSTEM-WIDE ENV TEMPLATE
# ==============================================================================
# This template defines variables required to run the Taskra autonomous engine,
# APIs, and dashboard client. Duplicate this file as '.env' for local dev or
# configure these values in your cloud console (Railway, Vercel, Supabase, Upstash).

# ------------------------------------------------------------------------------
# 1. CORE CONFIGURATION
# ------------------------------------------------------------------------------
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# 2. SUPABASE POSTGRES CONFIGURATION (Database Hosting)
# ------------------------------------------------------------------------------
# PostgreSQL transaction connection string. (Supabase provides this on port 6543
# with PgBouncer enabled, or port 5432 for direct connection).
# Example: postgresql://postgres.xxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://<username>:<password>@<supabase-host>:<port>/<db-name>?schema=public&pgbouncer=true"

# Direct pool connection string for prisma schema migration or bootstrapping
# Example: postgresql://postgres:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://<username>:<password>@<supabase-host>:5432/<db-name>"

# ------------------------------------------------------------------------------
# 3. UPSTASH REDIS INTEGRATION (Realtime Event & Queue Cache)
# ------------------------------------------------------------------------------
# Production Upstash connection URI. Ensure rediss:// is used for SSL/TLS, and
# URL is properly encoded with auth credentials.
# Example: rediss://default:xxxxxx@us1-active-whale-40001.upstash.io:40001
REDIS_URL="rediss://default:<password>@<upstash-host>:<upstash-port>"

# ------------------------------------------------------------------------------
# 4. SOMNIA L2 NETWORK PROTOCOL CONFIGURATION
# ------------------------------------------------------------------------------
# Hyper-scale RPC network nodes for smart-contract synchronization.
SOMNIA_RPC_URL="https://rpc.somnia.network"
SOMNIA_WS_URL="wss://rpc.somnia.network"

# On-chain TaskFactory registry contract address deployed on Somnia L2
TASK_FACTORY_ADDRESS="0x4016a2E42b575D764A9684F39274291B7b889307"

# ------------------------------------------------------------------------------
# 5. GROQ AI REASONING LAYER CONFIGURATION
# ------------------------------------------------------------------------------
# LLM reasoning API token (Used by background node agents for bid calculations).
# Retrieve from https://console.groq.com/keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------------------------------------------
# 6. NEXT.JS FRONTEND SPECIFICATIONS
# ------------------------------------------------------------------------------
# Public API gateway link consumed by the React dashboard (Socket.io & REST).
NEXT_PUBLIC_API_URL="https://taskra-api-production.up.railway.app"
NEXT_PUBLIC_SOCKET_URL="https://taskra-api-production.up.railway.app"
